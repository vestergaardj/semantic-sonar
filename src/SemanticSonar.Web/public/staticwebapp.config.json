{
  "routes": [
    {
      "route": "/.auth/*",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/api/*",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/models",
      "rewrite": "/models.html"
    },
    {
      "route": "/models/new",
      "rewrite": "/models/new.html"
    },
    {
      "route": "/models/import",
      "rewrite": "/models/import.html"
    },
    {
      "route": "/models/*",
      "rewrite": "/models/_shell_.html"
    },
    {
      "route": "/tenants",
      "rewrite": "/tenants.html"
    },
    {
      "route": "/tenants/*",
      "rewrite": "/tenants/_shell_/browse.html"
    },
    {
      "route": "/browse/*",
      "rewrite": "/browse/_shell_.html"
    },
    {
      "route": "/tags",
      "rewrite": "/tags.html"
    },
    {
      "route": "/audit",
      "rewrite": "/audit.html"
    },
    {
      "route": "/maintenance",
      "rewrite": "/maintenance.html"
    },
    {
      "route": "/uptime",
      "rewrite": "/uptime.html"
    },
    {
      "route": "/dependencies",
      "rewrite": "/dependencies.html"
    },
    {
      "route": "/radar",
      "rewrite": "/radar.html"
    },
    {
      "route": "/webhooks",
      "rewrite": "/webhooks.html"
    },
    {
      "route": "/api-test",
      "rewrite": "/api-test.html"
    },
    {
      "route": "/*",
      "allowedRoles": ["authenticated"]
    }
  ],
  "responseOverrides": {
    "401": {
      "redirect": "/.auth/login/aad?post_login_redirect_uri=/",
      "statusCode": 302
    }
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "SAMEORIGIN",
    "Strict-Transport-Security": "max-age=31536000; includeSubDomains"
  }
}
